---
import Layout from '../../layouts/Layout.astro';
const domain = '基础理论';
const icon = '🧩';
---

<Layout title={domain}>
  <div class="page-wrap">
    <div style="font-size:12px; color:#2563eb; font-weight:600; letter-spacing:1.5px; margin-bottom:12px;">
      <a href="/knowledge" style="color:#94a3b8;">知识体系</a> / {domain}
    </div>
    <h1 style="font-size:32px; font-weight:700; margin-bottom:8px;">{icon} {domain}</h1>
    <p style="color:#64748b; font-size:14px; margin-bottom:36px; max-width:600px;">
      Agent 范式、规划模式、记忆分层、Function Calling 机制、LLM 能力边界与局限。
    </p>
    <div style="background:white; border:1.5px solid #e2e8f0; border-radius:10px; padding:40px; text-align:center; color:#94a3b8; font-size:14px;">
      该分类下的文章正在策划中。
    </div>
  </div>
</Layout>
