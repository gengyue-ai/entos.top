---
import Layout from '../layouts/Layout.astro';

const domains = [
  { slug: '01-theory', icon: '🧩', title: '基础理论', desc: 'ReAct 范式、规划模式、记忆分层、Function Calling 机制、LLM 能力边界与局限。', count: '1 篇' },
  { slug: '02-architecture', icon: '🏗️', title: '架构设计', desc: '编排模式决策、MCP/A2A 协议、多 Agent 协作、多租户隔离、企业级扩展性与高可用设计。', count: '3 篇' },
  { slug: '03-engineering', icon: '⚙️', title: '工程实践', desc: '主流框架对比、MCP Server 开发、RAG 工程、可观测性、CI/CD 与部署流水线。', count: '3 篇' },
  { slug: '04-security', icon: '🛡️', title: '安全与治理', desc: 'Prompt 注入防护、数据隐私合规、审计链设计、Human-in-the-loop 实践模式。', count: '1 篇' },
  { slug: '05-evaluation', icon: '📊', title: '评估与优化', desc: 'Agent 评估方法论、成本模型与优化策略、模型路由、反馈闭环与持续改进。', count: '1 篇' },
  { slug: '06-strategy', icon: '🎯', title: '业务与战略', desc: '场景识别框架、ROI 计算模型、组织采纳路径、行业案例库与最佳实践。', count: '撰写中' },
];
---

<Layout title="知识域" description="六大知识域覆盖从理论到实践的完整链路——基础理论、架构设计、工程实践、安全治理、评估优化、业务战略。">
  <style>
    .page { max-width: 1100px; margin: 0 auto; padding: 60px 80px; }
    .label { font-size: 12px; color: #2563eb; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 12px; }
    .label::before { content: '— '; }
    .label::after { content: ' —'; }
    h1 { font-size: 32px; font-weight: 700; margin-bottom: 8px; color: #0f172a; }
    .desc { color: #334155; font-size: 14px; margin-bottom: 40px; max-width: 600px; line-height: 1.7; }
    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
    .card { display: block; background: #ffffff; border: 1.5px solid #e2e8f0; border-radius: 10px; padding: 24px; transition: border-color .15s; text-decoration: none; }
    .card:hover { border-color: #2563eb; }
    .card-icon { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 22px; border: 1px solid #e2e8f0; margin-bottom: 14px; }
    .card h3 { font-size: 16px; font-weight: 600; color: #0f172a; margin-bottom: 6px; }
    .card p { font-size: 13px; color: #334155; line-height: 1.7; }
    .card-meta { font-size: 12px; color: #475569; margin-top: 14px; padding-top: 12px; border-top: 1px solid #f1f5f9; }
    @media (max-width: 768px) { .page { padding: 40px 24px; } .grid { grid-template-columns: 1fr; } }
  </style>
  <div class="page">
    <div class="label">Knowledge Domains</div>
    <h1>六大知识域</h1>
    <p class="desc">覆盖从理论到实践的完整链路。每篇文章对应一个具体的学习目标。</p>
    <div class="grid">
      {domains.map(d => (
        <a href={`/knowledge/${d.slug}`} class="card">
          <div class="card-icon">{d.icon}</div>
          <h3>{d.title}</h3>
          <p>{d.desc}</p>
          <div class="card-meta">{d.count}</div>
        </a>
      ))}
    </div>
  </div>
</Layout>
