---
import Layout from '../layouts/Layout.astro';
---

<Layout title="文章">
  <div class="page-wrap">
    <div style="font-size:12px; color:#2563eb; font-weight:600; letter-spacing:1.5px; margin-bottom:12px;">— Articles —</div>
    <h1 style="font-size:32px; font-weight:700; margin-bottom:8px;">全部文章</h1>
    <p style="color:#64748b; font-size:14px; margin-bottom:36px;">以输出倒逼输入——每篇文章都是一个完整的学习闭环。</p>
    <div style="background:white; border:1.5px solid #e2e8f0; border-radius:10px; padding:40px; text-align:center; color:#94a3b8; font-size:14px;">
      文章正在策划中，即将发布。<br>敬请期待。
    </div>
  </div>
</Layout>
