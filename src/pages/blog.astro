const articles = [
  { tag: '工具', phase: 'Phase 1', level: 'practice', title: '用 FireCrawl + MCP 打通 AI 的信息获取通道', slug: 'firecrawl-mcp-plan', date: '2026.07.13', status: 'green', statusText: '已发布', desc: 'AI 的输出质量取决于它能获取到什么信息。通过 FireCrawl + MCP 协议，让 AI Agent 实时抓取互联网最新数据。' },
  { tag: '工程实践', phase: 'Phase 2', level: 'core', title: '给你的 Loop 一个名字——如何在现有系统中实现显式 Loop 声明', slug: 'explicit-loop-declaration', date: '2026.07.09', status: 'green', statusText: '已发布', desc: '隐藏的 Loop 不可观测、不可调试、不可治理。四步方案：命名 → 声明 → 观测 → 治理。每一步都有代码实现。' },
  { tag: 'Harness', phase: 'Phase 1', level: 'core', title: 'Agent Loop 是什么？我用 Harness 做了半年，发现它就是 Loop Engineering', slug: 'agent-loop-engineering', date: '2026.07.09', status: 'green', statusText: '已发布', desc: '硅谷最火的概念。Open Cloud 和 Cloud Code 创始人都在说"我不写 Prompt 了，我写 Loops"。我用 Harness 做了半年，发现它就是 Loop Engineering。' },
  { tag: '业务与战略', phase: 'Phase 3', level: 'core', title: '企业 Agent 落地五步法——从场景选择到持续运营的完整路径', slug: 'enterprise-agent-five-steps', date: '2026.07.09', status: 'green', statusText: '已发布', desc: '一个系统化的五步框架：场景识别→技术验证→试点运行→规模推广→持续运营。每一步都有明确的门槛和退出标准。' },
