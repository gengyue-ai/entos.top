  { tag: '基础理论', phase: 'Phase 1', level: 'core', title: 'ReAct 范式——我每天都在用 ReAct，但花了一整年才真正理解它', slug: 'react-paradigm', date: '2026.07.09', status: 'green', statusText: '已发布', desc: '三种规划模式的选择直接决定了 Agent 系统的成本、可靠性和开发复杂度。踩过的坑和得出的判断。' },
  { tag: '工程实践', phase: 'Phase 2', level: 'core', title: '框架选型指南——LangGraph / CrewAI / Dify / AutoGen 横评', slug: 'framework-comparison', date: '2026.07.05', status: 'green', statusText: '已发布', desc: '四个主流框架的设计哲学、适用场景和选型决策方法。没有最好的框架，只有最合适的。' },
  { tag: '评估与优化', phase: 'Phase 2', level: 'core', title: '成本模型——Agent 不是越强越好', slug: 'cost-model', date: '2026.07.05', status: 'green', statusText: '已发布', desc: 'Token 成本、模型路由、缓存策略、Token 压缩、ROI 计算——五个维度的成本优化方法论。' },
  { tag: '工程实践', phase: 'Phase 2', level: 'core', title: 'RAG 不是把文档扔进去——检索增强生成工程实战', slug: 'rag-engineering', date: '2026.07.05', status: 'green', statusText: '已发布', desc: 'Chunking、Embedding、检索优化、重排序、生成优化、评估——RAG 是一条完整的工程流水线，不是把文档扔进 Prompt。' },
  { tag: '工程实践', phase: 'Phase 2', level: 'core', title: 'Agent 可观测性——没有追踪就没有信任', slug: 'agent-observability', date: '2026.07.04', status: 'green', statusText: '已发布', desc: '传统软件能打断点，Agent 出错了你连它刚才想了什么都不知道。' },
  { tag: '行业全景', phase: 'Phase 1', level: 'reference', title: '企业级智能体在 2026 年的真实面貌', slug: 'enterprise-agent-2026', date: '2026.07.04', status: 'green', statusText: '已发布', desc: '不谈概念，只讲现实。AI Agent 到底走到了哪一步，以及传统企业应该怎么办。' },
  { tag: '知识体系', phase: 'Phase 1', level: 'reference', title: '企业级智能体六大知识域总览', slug: 'six-knowledge-domains', date: '2026.07.04', status: 'green', statusText: '已发布', desc: '一张知识地图——这个领域到底有多大、从哪里开始、每一步通向哪里。' },
  { tag: '工程实践', phase: 'Phase 2', level: 'practice', title: '自进化 Agent 落地记录——从方案到可运行的全链路代码', slug: 'self-evolving-implementation-report', date: '2026.07.09', status: 'green', statusText: '已发布', desc: '6 小时完成了自进化引擎的数据库、采集器、分析器、进化器、沙箱、治理层全部代码，全链路测试通过。' },
  { tag: '工程实践', phase: 'Phase 2', level: 'core', title: '自进化 Agent 实施计划——代码架构、数据设计、部署方案', slug: 'self-evolving-agent-implementation', date: '2026.07.09', status: 'green', statusText: '已发布', desc: '从架构设计到代码落地——数据库设计、模块实现、对接方案、三阶段上线计划。纯工程视角。' },
  { tag: 'Harness', phase: 'Phase 1', level: 'core', title: '企业级自进化 Agent 系统设计方案', slug: 'self-evolving-agent-design', date: '2026.07.09', status: 'green', statusText: '已发布', desc: '一套完整的企业级自进化智能体架构——五层分离、Skill 生命周期、Harness + 分层记忆、审批门禁与回滚机制。' },
  { tag: '学习周记', phase: 'Phase 1', level: 'reference', title: '学习周记 #2 · 服务器迁移与 LangGraph 实战周', slug: 'learning-journal-2', date: '2026.07.08', status: 'green', statusText: '已发布', desc: '从 WSL 到阿里云、34 篇文章、LangGraph 实战跑通——这一周做了过去一个月的事。' },
  { tag: '工程实践', phase: 'Phase 2', level: 'practice', title: 'LangGraph 实战总结——图编排 vs 手工调度，什么时候该用哪个', slug: 'langgraph-vs-delegatetask-summary', date: '2026.07.08', status: 'green', statusText: '已发布', desc: '花了两天用 LangGraph 搭多 Agent 流水线，和自己的 delegate_task 方案做了对比。结论：不是替代关系，是互补关系。' },
  { tag: '工程实践', phase: 'Phase 2', level: 'practice', title: 'LangGraph 多 Agent 实战记录', slug: 'langgraph-multi-agent-practice', date: '2026.07.08', status: 'green', statusText: '已发布', desc: '用 LangGraph 的 StateGraph 搭一个多 Agent 文档分析流水线。边做边写，全透明——环境搭建、代码实现、踩坑记录、对比总结，每一步实时更新。' },
  { tag: 'Harness', phase: 'Phase 1', level: 'core', title: '什么是 Harness——让大模型稳定产出可控结果的方法论体系', slug: 'what-is-harness', date: '2026.07.08', status: 'green', statusText: '已发布', desc: 'Harness 不是框架，不是工具，是工程规范。从上下文管理到知识沉淀，四个维度回答一个问题：如何让不可控的模型，稳定地产出可控的结果？' },
  { tag: '行业全景', phase: 'Phase 1', level: 'reference', title: '2026 AI 智能体大会给我的 3 个信号——Harness 不是自嗨，记忆是共识', slug: 'ai-agent-conference-2026-signals', date: '2026.07.08', status: 'green', statusText: '已发布', desc: '刚结束的中国 AI 智能体大会上，Harness 是十大议题之一。不是"要不要做"，而是"怎么落地"。三个信号告诉我：方向对了，但差距在哪里。' },
  { tag: '架构设计', phase: 'Phase 2', level: 'core', title: '多 Agent 技术栈地图——你的体系 vs LangGraph vs Dify', slug: 'multi-agent-tech-stack', date: '2026.07.08', status: 'green', statusText: '已发布', desc: 'Hermes + Harness、LangGraph、Dify——三者在多 Agent 系统中分别扮演什么角色？一张图看清定位，然后自然知道什么时候该用哪个。' },
  { tag: 'Harness', phase: 'Phase 1', level: 'practice', title: '多 Agent 编排模式实战——6 种模式，挑一种现在就上路', slug: 'multi-agent-orchestration-patterns', date: '2026.07.07', status: 'green', statusText: '已发布', desc: '当你手上的 Agent 从 1 个变成 N 个，你用什么方式把它们组织起来？6 种经过了验证的编排模式，从 Supervisor-Worker 到 StateGraph，每种都有对比表和适用场景。' },
  { tag: 'Harness', phase: 'Phase 1', level: 'core', title: '从作坊到工厂——我的 AI Agent 集群升级四步路线图', slug: 'workshop-to-factory-agent-cluster-upgrade', date: '2026.07.07', status: 'green', statusText: '已发布', desc: 'Agent 流水线跑通了，多 Agent 协作验证了——但架构还是作坊级的。上云、Kanban、质量门、自我进化，四步从作坊到工厂。' },
  { tag: 'Harness', phase: 'Phase 1', level: 'practice', title: '半小时实现一个 Hook 系统——从理论到落地', slug: 'hook-system-implementation', date: '2026.07.07', status: 'green', statusText: '已发布', desc: '写完了 Hook 的理论文章，然后照着做了一个。结果半小时从零到跑通。Hook 系统核心只有三样东西：注册表 + 动作函数 + 引擎。' },
  { tag: '架构设计', phase: 'Phase 2', level: 'core', title: 'LangChain 与 LangGraph 的本质区别——同一个公司的两种武器', slug: 'langchain-vs-langgraph-essence', date: '2026.07.07', status: 'green', statusText: '已发布', desc: 'LangChain 和 LangGraph 是竞品吗？都不是。LangChain 官方文档一句话说清了：LangChain 的 Agent 建立在 LangGraph 之上。它们是上下层，不是替代关系。' },
  { tag: '行业全景', phase: 'Phase 1', level: 'reference', title: '大多数公司只走到了 AI 的 5%——一个 20 年 IT 老兵的真实观察', slug: 'majority-companies-ai-5-percent', date: '2026.07.07', status: 'green', statusText: '已发布', desc: '霍夫曼说大多数公司 AI 落地只到 5%。一个经历了 ERP、大数据、云三次技术浪潮的 IT 老兵告诉你：不是技术买不起，是组织改不动。' },
  { tag: 'Harness', phase: 'Phase 1', level: 'practice', title: '技能即资产——我们用 2 小时标准化了 20 个 AI Skills', slug: 'skills-as-assets-standardization', date: '2026.07.07', status: 'green', statusText: '已发布', desc: '240 个技能，格式参差不齐。ECC 理论落地第一步：定义标准模板，批量升级 20 个最常用技能。2 小时做了什么、学到了什么。' },
  { tag: 'Harness', phase: 'Phase 1', level: 'core', title: '从 Session 到 Skill——AI Agent 如何自我进化', slug: 'session-to-skill-continuous-learning', date: '2026.07.07', status: 'green', statusText: '已发布', desc: '每天产生几十条会话数据，除了翻出来看还有什么用？连续学习把"翻历史→找模式→写 skill"自动化——四步管道从 Session 到 Skill，产生复利效应。' },
  { tag: 'Harness', phase: 'Phase 1', level: 'core', title: 'Hook 系统——工具调用的前与后', slug: 'hook-system', date: '2026.07.07', status: 'green', statusText: '已发布', desc: 'Agent 的本质是工具调用循环。Hook 系统在工具调用前后插一脚——安全检查、自动质检、连续学习，把"靠人记着做"变成"系统自动做"。' },
  { tag: 'Harness', phase: 'Phase 1', level: 'core', title: 'AI Agent 不只是模型——从 ECC 看 Agent 操作系统的五层架构', slug: 'ai-agent-os-five-layer-architecture', date: '2026.07.07', status: 'green', statusText: '已发布', desc: '一个好的 Agent 不是"模型+提示词"的堆砌，而是一个有五层架构的操作系统。从 ECC 的 22 万 Star 看分层设计的必要性。' },
  { tag: '架构设计', phase: 'Phase 2', level: 'core', title: '多Agent 协作——Supervisor-Worker 模式的实战经验', slug: 'multi-agent-collaboration', date: '2026.07.07', status: 'green', statusText: '已发布', desc: '什么时候用单Agent，什么时候拆成多个？并行分发、流水线、动态委派三种模式的实际工程经验。' },
  { tag: 'Harness', phase: 'Phase 1', level: 'core', title: '记忆系统的可观测性与调试', slug: 'memory-observability', date: '2026.07.07', status: 'green', statusText: '已发布', desc: '你不知道 Agent 记得什么，就无法调试它。三个观测维度、Memory Bank 模式、5 步排查流程。' },
  { tag: 'Harness', phase: 'Phase 1', level: 'core', title: '遗忘的艺术——什么时候该忘记', slug: 'forgetting', date: '2026.07.07', status: 'green', statusText: '已发布', desc: '没有遗忘策略的记忆系统，就是堆满旧物的仓库。TTL、衰减、版本覆盖三种策略，以及不遗忘的三类代价。' },
  { tag: '学习周记', phase: 'Phase 1', level: 'reference', title: '学习周记 #1 · 记忆系统启动与网站框架重构', slug: 'learning-journal-1', date: '2026.07.07', status: 'green', statusText: '已发布', desc: '网站框架改造完成、记忆系统系列启动中、导航重新设计。一周回顾与下周计划。' },
  { tag: 'Harness', phase: 'Phase 1', level: 'core', title: '情景记忆——Agent 如何记住自己做过什么', slug: 'episodic-memory', date: '2026.07.07', status: 'green', statusText: '已发布', desc: '跨会话记忆是"断片"的重灾区。存什么、怎么存、怎么取——从结构化设计到与 Hermes 现有工具的对接方案。' },
  { tag: 'Harness', phase: 'Phase 1', level: 'core', title: '工作记忆管理——不要让 Token 成为瓶颈', slug: 'working-memory', date: '2026.07.07', status: 'green', statusText: '已发布', desc: '更大的上下文不等于更好的记忆。注意力衰减是硬约束。分层结构、摘要压缩、优先级保留——三种策略组合让 Agent 在有限上下文内记住关键信息。' },
  { tag: 'Harness', phase: 'Phase 1', level: 'core', title: '三层记忆模型——工作记忆、情景记忆、语义知识', slug: 'three-layer-memory', date: '2026.07.07', status: 'green', statusText: '已发布', desc: '工作记忆管当前会话、情景记忆管历史交互、语义知识管长期沉淀。三层对应三种不同的信息生命周期，也意味着三种不同的存储方案和检索策略。' },
  { tag: 'Harness', phase: 'Phase 1', level: 'core', title: 'Agent 的"失忆症"——为什么 LLM 记不住事', slug: 'agent-amnesia', date: '2026.07.07', status: 'green', statusText: '已发布', desc: '开发过程中 Agent 频繁"断片"——长对话健忘、新会话归零、重复问题。这不是模型不够聪明，是记忆架构没有设计。' },
  { tag: '案例复盘', phase: 'Phase 1', level: 'practice', title: '可配置化风控告警引擎——不要让规则写在代码里', slug: 'alert-engine-case', date: '2026.07.06', status: 'green', statusText: '已发布', desc: '告警规则写在代码里，改一条规则就要改代码、测试、部署。可配置化之后，新增一条规则只需要 INSERT 一条记录。' },
  { tag: 'Harness', phase: 'Phase 1', level: 'core', title: '输出约束——让模型说"该说的话"', slug: 'output-constraints', date: '2026.07.06', status: 'green', statusText: '已发布', desc: '模型什么都能说出来，但你要的只是它"该说的那部分"。输出约束就是在模型开口之前，给它的回答画好边界。' },
  { tag: 'Harness', phase: 'Phase 1', level: 'core', title: '知识沉淀——从对话中提取可复用的资产', slug: 'knowledge-precipitation', date: '2026.07.06', status: 'green', statusText: '已发布', desc: '每一次 Agent 交互都会产生有价值的信息。知识沉淀就是从对话中提取模式、坑点、决策，让经验不随着对话结束而蒸发。' },
  { tag: 'Harness', phase: 'Phase 1', level: 'core', title: '验证闭环——让模型的每一次输出都经过检验', slug: 'validation-loop', date: '2026.07.06', status: 'green', statusText: '已发布', desc: '模型的输出不可信，这是一个前提，不是一个 bug。验证闭环就是在每一个关键输出后面加一道检查。' },
  { tag: 'Harness', phase: 'Phase 1', level: 'core', title: '上下文管理——模型的记忆边界在哪里', slug: 'context-management', date: '2026.07.06', status: 'green', statusText: '已发布', desc: '上下文窗口再大也是有限的。好的上下文管理不是"塞更多"，而是"知道该放什么、该扔什么"。' },
  { tag: '案例复盘', phase: 'Phase 1', level: 'practice', title: '从硬编码到配置化——星辉广告系统的同步引擎 V2 改造实录', slug: 'sync-engine-v2-case', date: '2026.07.06', status: 'green', statusText: '已发布', desc: '一个广告中介平台的同步引擎，从每个上游写一份硬编码逻辑，到零代码配置化接入的完整过程。' },
];

