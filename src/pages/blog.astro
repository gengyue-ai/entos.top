  { id: 'overview', name: '行业全景', icon: '🌐',
    tags: ['行业全景', '知识体系', '学习周记'],
    articles: articles.filter(a => ['行业全景', '知识体系', '学习周记'].includes(a.tag)) },
];

const phaseLabels = { 'Phase 1': '实战者', 'Phase 2': '架构师', 'Phase 3': '顾问' };
const levelLabels = { 'core': '核心', 'practice': '实战', 'reference': '参考' };
---

<Layout title="文章">
  <style>
    .page { max-width: 1100px; margin: 0 auto; padding: 60px 80px; }
    .label { font-size: 12px; color: #2563eb; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 12px; }
    .label::before { content: '— '; } .label::after { content: ' —'; }
    h1 { font-size: 32px; font-weight: 700; margin-bottom: 8px; color: #0f172a; }
    .desc { color: #334155; font-size: 14px; margin-bottom: 32px; max-width: 600px; line-height: 1.7; }

    /* Search + Filter */
    .search-box { width: 100%; padding: 12px 16px; border: 1.5px solid #e2e8f0; border-radius: 8px; font-size: 14px; outline: none; margin-bottom: 16px; background: #ffffff; color: #0f172a; transition: border-color .15s; }
    .search-box:focus { border-color: #2563eb; }
    .cat-bar { display: flex; gap: 8px; margin-bottom: 28px; flex-wrap: wrap; }
    .cat-btn { padding: 8px 18px; border-radius: 8px; font-size: 13px; font-weight: 500; border: 1.5px solid #e2e8f0; background: #ffffff; color: #334155; cursor: pointer; transition: all .15s; display: flex; align-items: center; gap: 6px; }
    .cat-btn:hover { border-color: #2563eb; color: #2563eb; }
    .cat-btn.active { background: #2563eb; color: white; border-color: #2563eb; }

    /* Category section */
    .category { margin-bottom: 36px; }
    .cat-header { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; padding-bottom: 8px; border-bottom: 2px solid #e2e8f0; }
    .cat-icon { font-size: 20px; }
    .cat-name { font-size: 17px; font-weight: 700; color: #0f172a; }
    .cat-count { font-size: 12px; color: #94a3b8; }

    /* Article list */
    .list { display: flex; flex-direction: column; gap: 0; background: #ffffff; border: 1.5px solid #e2e8f0; border-radius: 10px; overflow: hidden; }
    .item { display: block; padding: 16px 20px; border-bottom: 1px solid #f1f5f9; text-decoration: none; transition: background .15s; }
    .item:last-child { border-bottom: none; }
    .item:hover { background: #f8fafc; }
    .top { display: flex; align-items: center; gap: 8px; margin-bottom: 4px; flex-wrap: wrap; }
    .tag { font-size: 11px; padding: 2px 8px; border-radius: 4px; background: #eef2ff; color: #4338ca; font-weight: 500; }
    .phase-badge { font-size: 10px; padding: 2px 6px; border-radius: 3px; font-weight: 600; }
    .phase-1 { background: #dcfce7; color: #166534; }
    .phase-2 { background: #fef3c7; color: #92400e; }
    .phase-3 { background: #f5f3ff; color: #5b21b6; }
    .level-badge { font-size: 10px; padding: 2px 6px; border-radius: 3px; color: #475569; background: #f1f5f9; }
    .date { font-size: 12px; color: #94a3b8; }
    .item h3 { font-size: 15px; font-weight: 600; color: #0f172a; margin-bottom: 2px; line-height: 1.4; }
    .item p { font-size: 12px; color: #475569; line-height: 1.5; margin: 0; }
    .no-result { font-size: 14px; color: #475569; text-align: center; padding: 60px 0; display: none; }

    @media (max-width: 768px) { .page { padding: 40px 24px; } }
  </style>

  <div class="page">
    <div class="label">Articles</div>
    <h1>全部文章</h1>
    <p class="desc">42 篇文章，按分类组织。搜索、筛选、分类——快速找到你需要的。</p>

    <input type="text" class="search-box" id="searchInput" placeholder="搜索文章标题或关键词…" oninput="filterArticles()"/>

    <div class="cat-bar" id="catBar">
      <button class="cat-btn active" onclick="filterByCategory('all', this)">📋 全部</button>
      {categories.map(c => (
        <button class="cat-btn" data-cat={c.id} onclick={"filterByCategory('" + c.id + "', this)"}>{c.icon} {c.name}</button>
      ))}
    </div>

    <div id="articleContainer">
      {categories.map(cat => (
        <div class="category" data-category={cat.id}>
          <div class="cat-header">
            <span class="cat-icon">{cat.icon}</span>
            <span class="cat-name">{cat.name}</span>
            <span class="cat-count">{cat.articles.length} 篇</span>
          </div>
          <div class="list">
            {cat.articles.map(a => (
              <a href={`/blog/${a.slug}`} class="item" style="display:block">
                <div class="top">
                  <span class="tag">{a.tag}</span>
                  <span class={"phase-badge phase-" + (a.phase === 'Phase 1' ? '1' : a.phase === 'Phase 2' ? '2' : '3')}>{phaseLabels[a.phase]}</span>
                  <span class="level-badge">{levelLabels[a.level]}</span>
                  <span class="date">{a.date}</span>
                </div>
                <h3>{a.title}</h3>
                <p>{a.desc}</p>
              </a>
            ))}
          </div>
        </div>
      ))}
    </div>

    <div class="no-result" id="noResult">没有找到匹配的文章</div>
  </div>

  <script is:inline>
    function filterByCategory(catId, btn) {
      // 更新按钮状态
      document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');

      // 显示/隐藏分类区块
      document.querySelectorAll('.category').forEach(el => {
        el.style.display = (catId === 'all' || el.dataset.category === catId) ? '' : 'none';
      });
      
      // 如果按了分类，清空搜索
      if (catId !== 'all') {
        document.getElementById('searchInput').value = '';
      }

      checkNoResult();
    }

    function filterArticles() {
      const q = document.getElementById('searchInput').value.toLowerCase().trim();
      
      // 如果有搜索内容，显示所有分类
      if (q) {
        document.querySelectorAll('.cat-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.category').forEach(el => el.style.display = '');
      }

      // 逐条过滤
      let visible = 0;
      document.querySelectorAll('.item').forEach(el => {
        const text = el.textContent.toLowerCase();
        const match = !q || text.includes(q);
        el.style.display = match ? '' : 'none';
        if (match) visible++;
      });

      document.getElementById('noResult').style.display = visible === 0 ? '' : 'none';
    }

    function checkNoResult() {
      const visible = document.querySelectorAll('.item[style*="display: block"], .item:not([style*="display: none"])').length;
      // 实际上所有未设置display的item都是可见的
      let count = 0;
      document.querySelectorAll('.item').forEach(el => {
        if (el.style.display !== 'none') count++;
      });
      document.getElementById('noResult').style.display = count === 0 ? '' : 'none';
    }
  </script>
</Layout>