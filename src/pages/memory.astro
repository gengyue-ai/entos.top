---
import Layout from '../layouts/Layout.astro';

const layers = [
  {
    icon: '🧠',
    name: '工作记忆',
    eng: 'Working Memory',
    desc: '当前会话的上下文管理。控制 Token 预算、优先级保留策略、会话摘要压缩。',
    tag: '当前会话',
    tagClass: 'blue',
    aspects: ['Token 预算', '优先级保留', '摘要压缩'],
    harness: 'Harness · 上下文管理',
  },
  {
    icon: '📝',
    name: '情景记忆',
    eng: 'Episodic Memory',
    desc: '跨会话的历史交互记录。会话持久化、关键决策日志、语义检索与复现。',
    tag: '历史交互',
    tagClass: 'purple',
    aspects: ['会话持久化', '决策日志', '跨会话检索'],
    harness: '学习中',
  },
  {
    icon: '📚',
    name: '语义知识',
    eng: 'Semantic Knowledge',
    desc: '长期积累的结构化知识。可复用的技能库、连接的知识图谱、固化的工作模式。',
    tag: '长期积累',
    tagClass: 'teal',
    aspects: ['技能库', '知识图谱', '模式固化'],
    harness: 'Harness · 知识沉淀',
  },
];

const articles = [
  { num: 1, title: 'Agent 的"失忆症"——为什么 LLM 记不住事', status: 'published', slug: 'agent-amnesia' },
  { num: 2, title: '三层记忆模型：工作记忆、情景记忆、语义知识', status: 'published', slug: 'three-layer-memory' },
  { num: 3, title: '工作记忆管理——不要让 Token 成为瓶颈', status: 'published', slug: 'working-memory' },
  { num: 4, title: '情景记忆——Agent 如何记住自己做过什么', status: 'published', slug: 'episodic-memory' },
  { num: 5, title: '遗忘的艺术——什么时候该忘记', status: 'published', slug: 'forgetting' },
  { num: 6, title: '记忆系统的可观测性与调试', status: 'published', slug: 'memory-observability' },
];
---

<Layout title="记忆系统" description="从三层记忆模型到工程实现。解决 Agent '断片'的根本方法。">
  <style>
    .page { max-width: 1100px; margin: 0 auto; padding: 60px 80px; }

    /* Hero */
    .hero { margin-bottom: 48px; }
    .hero-badge { display: inline-flex; align-items: center; gap: 6px; padding: 4px 14px; border-radius: 20px; font-size: 12px; font-weight: 600; background: #f5f3ff; color: #7c3aed; border: 1px solid #ddd6fe; margin-bottom: 16px; letter-spacing: 0.5px; }
    .hero-badge-dot { width: 6px; height: 6px; border-radius: 50%; background: #7c3aed; }
    h1 { font-size: 42px; font-weight: 800; line-height: 1.15; letter-spacing: -0.5px; color: #0f172a; margin-bottom: 12px; }
    .gradient { background: linear-gradient(135deg, #7c3aed, #a78bfa); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }
    .hero-sub { font-size: 16px; color: #334155; line-height: 1.7; max-width: 680px; margin-bottom: 6px; }

    /* Intro */
    .intro { background: #ffffff; border: 1.5px solid #e2e8f0; border-radius: 12px; padding: 32px; margin-bottom: 48px; }
    .intro-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: start; }
    .intro-left p { font-size: 14px; color: #334155; line-height: 1.8; }
    .intro-left p + p { margin-top: 12px; }
    .intro-right { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 8px; padding: 24px; }
    .pillar-title { font-size: 13px; font-weight: 600; color: #0f172a; margin-bottom: 16px; }
    .pillar-compare { display: flex; flex-direction: column; gap: 12px; }
    .pillar-row { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 8px; background: #ffffff; border: 1px solid #e2e8f0; }
    .pillar-icon { width: 32px; height: 32px; border-radius: 6px; display: flex; align-items: center; justify-content: center; font-size: 14px; flex-shrink: 0; }
    .pillar-icon.harness { background: #eef2ff; border: 1px solid #bfdbfe; }
    .pillar-icon.memory { background: #f5f3ff; border: 1px solid #ddd6fe; }
    .pillar-name { font-size: 13px; font-weight: 600; color: #0f172a; min-width: 48px; }
    .pillar-desc { font-size: 12px; color: #334155; line-height: 1.5; }
    .pillar-number { font-size: 10px; font-weight: 700; color: #475569; margin-left: auto; letter-spacing: 0.5px; }

    /* Section */
    .sec-label { font-size: 12px; color: #7c3aed; font-weight: 600; letter-spacing: 1.5px; text-transform: uppercase; margin-bottom: 12px; }
    .sec-label::before { content: '— '; } .sec-label::after { content: ' —'; }
    .sec-title { font-size: 28px; font-weight: 700; color: #0f172a; margin-bottom: 36px; }

    /* Three-layer cards */
    .layer-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; margin-bottom: 48px; }
    .layer-card { background: #ffffff; border: 1.5px solid #e2e8f0; border-radius: 12px; padding: 28px; transition: border-color .15s, transform .15s; display: flex; flex-direction: column; }
    .layer-card:hover { border-color: #7c3aed; transform: translateY(-3px); box-shadow: 0 8px 24px rgba(124,58,237,0.08); }
    .layer-head { display: flex; align-items: flex-start; justify-content: space-between; margin-bottom: 12px; }
    .layer-icon { width: 44px; height: 44px; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
    .layer-icon.blue { background: #eef2ff; border: 1px solid #bfdbfe; }
    .layer-icon.purple { background: #f5f3ff; border: 1px solid #ddd6fe; }
    .layer-icon.teal { background: #f0fdfa; border: 1px solid #a7f3d0; }
    .layer-tag { font-size: 11px; padding: 2px 10px; border-radius: 12px; font-weight: 500; }
    .layer-tag.blue { background: #eef2ff; color: #4338ca; }
    .layer-tag.purple { background: #f5f3ff; color: #7c3aed; }
    .layer-tag.teal { background: #f0fdfa; color: #0d9488; }
    .layer-name { font-size: 18px; font-weight: 700; color: #0f172a; margin-bottom: 2px; }
    .layer-eng { font-size: 12px; color: #475569; font-weight: 400; margin-bottom: 8px; }
    .layer-desc { font-size: 13px; color: #334155; line-height: 1.7; margin-bottom: 16px; flex: 1; }
    .layer-aspects { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 16px; }
    .layer-aspect { font-size: 11px; padding: 3px 10px; border-radius: 4px; background: #f8fafc; color: #334155; border: 1px solid #e2e8f0; }
    .layer-harness { font-size: 11px; color: #475569; padding-top: 12px; border-top: 1px solid #f1f5f9; }
    .layer-harness strong { color: #334155; font-weight: 600; }

    /* Articles planning */
    .plan-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; margin-bottom: 48px; }
    .plan-card { background: #ffffff; border: 1.5px solid #e2e8f0; border-radius: 10px; padding: 20px; transition: border-color .15s; text-decoration: none; display: block; color: inherit; }
    .plan-card:hover { border-color: #7c3aed; }
    .plan-card-planned { border-style: dashed; border-color: #d4d4d8; }
    .plan-card-planned:hover { border-color: #7c3aed; border-style: dashed; }
    .plan-num { font-size: 11px; font-weight: 700; color: #a1a1aa; margin-bottom: 6px; letter-spacing: 0.5px; }
    .plan-title { font-size: 14px; font-weight: 600; color: #0f172a; line-height: 1.5; margin-bottom: 8px; }
    .plan-status { display: inline-flex; align-items: center; gap: 4px; font-size: 11px; padding: 2px 10px; border-radius: 12px; font-weight: 500; }
    .plan-status-published { background: #dcfce7; color: #166534; }
    .plan-status-published::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: #22c55e; }
    .plan-status-planned { background: #f1f5f9; color: #334155; }
    .plan-status-planned::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: #94a3b8; }

    /* Related */
    .related { background: linear-gradient(135deg, #f5f3ff, #eef2ff); border: 1.5px solid #ddd6fe; border-radius: 12px; padding: 28px 32px; display: flex; align-items: center; justify-content: space-between; }
    .related-left h3 { font-size: 16px; font-weight: 700; color: #0f172a; margin-bottom: 6px; }
    .related-left p { font-size: 13px; color: #334155; line-height: 1.6; }
    .related-link { display: inline-flex; align-items: center; gap: 6px; padding: 10px 24px; background: #7c3aed; color: white; border-radius: 8px; font-size: 14px; font-weight: 600; transition: background .15s; flex-shrink: 0; }
    .related-link:hover { background: #6d28d9; }

    @media (max-width: 768px) {
      .page { padding: 40px 24px; }
      .intro-grid { grid-template-columns: 1fr; gap: 20px; }
      .layer-grid { grid-template-columns: 1fr; }
      .plan-grid { grid-template-columns: 1fr; }
      .related { flex-direction: column; gap: 16px; text-align: center; }
      h1 { font-size: 30px; }
    }
  </style>

  <div class="page">
    <!-- Hero -->
    <section class="hero">
      <div class="hero-badge">
        <span class="hero-badge-dot"></span>
        Harness · 第二支柱
      </div>
      <h1>记忆系统</h1>
      <p class="hero-sub">让模型记住该记住的事——<span class="gradient">跨会话状态持久化的工程方法</span></p>
    </section>

    <!-- Intro -->
    <section class="intro">
      <div class="intro-grid">
        <div class="intro-left">
          <p>
            <strong>Harness 管输出，记忆系统管记忆</strong>——这是控制层的核心分工。Harness 确保模型的每一次输出都是可控、可验证、可追溯的；而记忆系统解决的是更深层的问题：模型怎么不"断片"？
          </p>
          <p>
            一个没有记忆系统的 Agent，每次会话都是一张白纸。它记不住用户偏好，记不住之前的决策，记不住自己已经探索过的路径。三层记忆模型从工作记忆、情景记忆到语义知识，为 Agent 建立起从短期到长期、从原始到结构化的完整状态管理。
          </p>
        </div>
        <div class="intro-right">
          <div class="pillar-title">控制层 · 双支柱</div>
          <div class="pillar-compare">
            <div class="pillar-row">
              <div class="pillar-icon harness">⚙️</div>
              <span class="pillar-name">Harness</span>
              <span class="pillar-desc">管控模型的输出质量</span>
              <span class="pillar-number">第一支柱</span>
            </div>
            <div class="pillar-row">
              <div class="pillar-icon memory">🧠</div>
              <span class="pillar-name">记忆系统</span>
              <span class="pillar-desc">管理模型的状态延续</span>
              <span class="pillar-number">第二支柱</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Three-layer Memory Model -->
    <section>
      <div class="sec-label">Three-Layer Memory Model</div>
      <div class="sec-title">三层记忆模型</div>
      <div class="layer-grid">
        {layers.map(l => (
          <div class="layer-card">
            <div class="layer-head">
              <div class={`layer-icon ${l.tagClass}`}>{l.icon}</div>
              <span class={`layer-tag ${l.tagClass}`}>{l.tag}</span>
            </div>
            <div class="layer-name">{l.name}</div>
            <div class="layer-eng">{l.eng}</div>
            <div class="layer-desc">{l.desc}</div>
            <div class="layer-aspects">
              {l.aspects.map(a => <span class="layer-aspect">{a}</span>)}
            </div>
            <div class="layer-harness">→ 关联：<strong>{l.harness}</strong></div>
          </div>
        ))}
      </div>
    </section>

    <!-- Article Planning -->
    <section>
      <div class="sec-label">Article Plan</div>
      <div class="sec-title">文章规划</div>
      <div class="plan-grid">
        {articles.map(a => (
          a.status === 'published' ? (
            <a href={`/blog/${a.slug}`} class="plan-card">
              <div class="plan-num">#{String(a.num).padStart(2, '0')}</div>
              <div class="plan-title">{a.title}</div>
              <span class="plan-status plan-status-published">已发布</span>
            </a>
          ) : (
            <div class="plan-card plan-card-planned">
              <div class="plan-num">#{String(a.num).padStart(2, '0')}</div>
              <div class="plan-title">{a.title}</div>
              <span class="plan-status plan-status-planned">即将发布</span>
            </div>
          )
        ))}
      </div>
    </section>

    <!-- Related Reading -->
    <section class="related">
      <div class="related-left">
        <h3>关联阅读</h3>
        <p>Harness 方法论——控制层的第一支柱，专注模型的输出质量控制。</p>
      </div>
      <a href="/harness" class="related-link">探索 Harness →</a>
    </section>
  </div>
</Layout>
