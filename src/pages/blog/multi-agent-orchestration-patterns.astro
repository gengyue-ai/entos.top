---
import Layout from '../../layouts/Layout.astro';
const title = '多 Agent 编排模式实战——6 种模式，挑一种现在就上路';
const desc = '当你手上的 Agent 从 1 个变成 N 个，你用什么方式把它们组织起来？6 种经过了验证的编排模式，从 Supervisor-Worker 到 StateGraph，每种都有对比表和适用场景。';
const date = '2026.07.07';
---

<Layout title={title} description={desc}>
  <style>
