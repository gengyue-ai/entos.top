const title = '三层记忆模型——工作记忆、情景记忆、语义知识';
const desc = '工作记忆管当前会话、情景保管历史交互、语义知识管长期沉淀。三层对应三种不同的信息生命周期，也意味着三种不同的存储方案和检索策略。';
const date = '2026.07.07';
---

<Layout title={title} description={desc}>
  <style>
