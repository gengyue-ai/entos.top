---
import Layout from '../layouts/Layout.astro';
---

<Layout title="案例">
  <div class="page-wrap">
    <div style="font-size:12px; color:#2563eb; font-weight:600; letter-spacing:1.5px; margin-bottom:12px;">— Cases —</div>
    <h1 style="font-size:32px; font-weight:700; margin-bottom:8px;">案例与实践</h1>
    <p style="color:#64748b; font-size:14px; margin-bottom:36px; max-width:600px;">真实业务场景中的 Agent 落地复盘——决策过程、踩坑记录、架构演进。</p>

    <div style="background:white; border:1.5px solid #e2e8f0; border-radius:10px; padding:24px; margin-bottom:16px;">
      <div style="font-size:11px; padding:3px 10px; border-radius:4px; background:#eef2ff; color:#4338ca; font-weight:500; display:inline-block; margin-bottom:10px;">五洲广告系统</div>
      <h3 style="font-size:16px; font-weight:600;">五洲广告系统的 Agent 落地实录</h3>
      <p style="font-size:13px; color:#64748b; margin-top:6px;">一个真实商用的广告中介平台，如何逐步引入 Agent 实现自动化运维、数据审计与异常告警。</p>
      <div style="font-size:12px; color:#eab308; margin-top:12px;">🟡 撰写中</div>
    </div>
  </div>
</Layout>
