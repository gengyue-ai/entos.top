---
// src/layouts/Layout.astro
export interface Props {
  title?: string;
  description?: string;
}

const { title = 'entos.top', description = '企业级智能体工程实践指南' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title} · entos.top</title>
  <meta name="description" content={description}>
  <meta property="og:title" content={`${title} · entos.top`}>
  <meta property="og:description" content={description}>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><rect width=%22100%22 height=%22100%22 rx=%2220%22 fill=%22%232563eb%22/><text x=%2250%22 y=%2272%22 font-size=%2260%22 font-weight=%22800%22 text-anchor=%22middle%22 fill=%22white%22 font-family=%22monospace%22>E</text></svg>">
  <link rel="alternate" type="application/rss+xml" title="entos.top" href="/rss.xml">
  <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml">
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', 'Noto Sans SC', -apple-system, BlinkMacSystemFont, sans-serif; background: #f8fafc; color: #0f172a; line-height: 1.6; }
    a { color: inherit; text-decoration: none; }

    /* Nav */
    nav { display: flex; align-items: center; justify-content: space-between; padding: 0 80px; height: 60px; background: #ffffff; border-bottom: 2px solid #e2e8f0; position: sticky; top: 0; z-index: 100; }
    .logo { display: flex; align-items: center; gap: 10px; font-weight: 700; font-size: 16px; color: #0f172a; }
    .logo-mark { width: 26px; height: 26px; background: linear-gradient(135deg, #2563eb, #7c3aed); border-radius: 6px; display: flex; align-items: center; justify-content: center; color: white; font-size: 13px; font-weight: 800; }
    .nav-links { display: flex; align-items: center; gap: 4px; }
    .nav-links a { color: #334155; font-size: 13px; font-weight: 500; padding: 8px 16px; border-radius: 6px; transition: all .15s; }
    .nav-links a:hover, .nav-links a.active { color: #2563eb; background: #f1f5f9; }
    .nav-cta { background: #0f172a !important; color: white !important; padding: 8px 20px !important; border-radius: 6px !important; margin-left: 12px; }
    .nav-cta:hover { background: #1e293b !important; color: white !important; }

    /* Footer */
    .footer { max-width: 1100px; margin: 0 auto; padding: 32px 80px; border-top: 1.5px solid #e2e8f0; display: flex; justify-content: space-between; color: #64748b; font-size: 13px; }
    .footer a { color: #334155; }
    .footer a:hover { color: #2563eb; }

    .divider { max-width: 1100px; margin: 0 auto; height: 0; border: none; border-top: 1px solid #e2e8f0; }
    .page-wrap { max-width: 1100px; margin: 0 auto; padding: 60px 80px; }

    @media (max-width: 768px) {
      nav { padding: 0 24px; }
      .nav-links a:not(.nav-cta) { display: none; }
      .page-wrap { padding: 40px 24px; }
      .footer { padding: 24px; flex-direction: column; gap: 6px; }
    }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="logo"><span class="logo-mark">E</span> entos.top</a>
    <div class="nav-links">
      <a href="/" class={Astro.url.pathname === '/' ? 'active' : ''}>首页</a>
      <a href="/roadmap" class={Astro.url.pathname.startsWith('/roadmap') ? 'active' : ''}>学习路径</a>
      <a href="/harness" class={Astro.url.pathname.startsWith('/harness') ? 'active' : ''}>方法论</a>
      <a href="/knowledge" class={Astro.url.pathname.startsWith('/knowledge') ? 'active' : ''}>知识域</a>
      <a href="/cases" class={Astro.url.pathname.startsWith('/cases') ? 'active' : ''}>案例</a>
      <a href="/blog" class={Astro.url.pathname.startsWith('/blog') ? 'active' : ''}>文章</a>
      <a href="/resources" class={Astro.url.pathname.startsWith('/resources') ? 'active' : ''}>资源库</a>
      <a href="/about" class={Astro.url.pathname.startsWith('/about') ? 'active' : ''}>关于</a>
      <a href="/rss.xml" class="nav-cta">RSS</a>
    </div>
  </nav>

  <slot />

  <div class="footer">
    <span>© 2026 entos.top · 企业级智能体工程实践</span>
    <span><a href="/rss.xml">RSS</a> · <a href="/about">关于</a></span>
  </div>
</body>
</html>
